---
// src/layouts/MainLayout.astro
import Navbar from '../components/global/Navbar.vue';
import Footer from '../components/global/Footer.astro';
import ScrollTop from '../components/global/ScrollTop.astro';
import WhatsAppButton from '../components/global/WhatsAppButton.astro';
import CallButton from '../components/global/CallButton.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { 
  title = "Grupo Transporte RG | Soluciones Logísticas", 
  description = "Servicio de transporte de carga y logística integral." 
} = Astro.props;

const menuItems = [
  { name: 'Inicio', url: '/', submenu: [] },
  { 
    name: 'Servicios', 
    url: '/servicios',
    submenu: [
      { name: 'Mudanzas', url: '/servicios/mudanzas' },
      { name: 'Acarreos', url: '/servicios/acarreos' },
      { name: 'Cargas Ligeras', url: '/servicios/cargas-ligeras' },
      { name: 'Cargas Pesadas', url: '/servicios/cargas-pesadas' },
      { name: 'Transporte de Motos "Varadas"', url: '/servicios/transporte-motos' }
    ] 
  },
  { 
    name: 'Nosotros', 
    url: '/nosotros', 
    submenu: [
      { name: 'Nuestra Historia', url: '/nosotros/historia' },
      { name: 'Misión y Visión', url: '/nosotros/mision-vision' },
      { name: 'Equipo', url: '/nosotros/equipo' },
      { name: 'Cobertura', url: '/nosotros/cobertura' }
    ] 
  },
  { 
    name: 'Contacto', 
    url: '/contacto', 
    submenu: [
        { name: 'Preguntas Frecuentes', url: '/contacto/faq' },
        { name: 'Escríbenos', url: '/proximamente' },
        { name: 'PQRS', url: '/proximamente' }
    ] 
  },
];
---

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
</head>
<body class="bg-[url('/img/background_fond.svg')] bg-cover bg-fixed bg-center text-[#1b1b18] dark:text-gray-100">
    <div class="flex min-h-screen flex-col items-center">
        <header id="main-header" class="fixed top-0 w-full z-50">
            <Navbar client:load initialMenuItems={menuItems} />
        </header>

        <main id="main-content" class="flex-1 w-full flex justify-center pt-[140px] md:pt-[160px]">
            <div class="w-full max-w-7xl bg-white dark:bg-black shadow-2xl overflow-hidden flex flex-col min-h-screen">
                <slot />
            </div>
        </main>

        <Footer />
        <CallButton />
        <WhatsAppButton />
        <ScrollTop />
    </div>

    <script is:inline>
        function updateMainPadding() {
            const header = document.querySelector('#main-header');
            const main = document.querySelector('#main-content');
            if (header && main) {
                // Añadimos un pequeño margen extra de 10px para que el contenido respire
                main.style.paddingTop = (header.offsetHeight + 10) + 'px';
            }
        }
        window.addEventListener('load', updateMainPadding);
        window.addEventListener('resize', updateMainPadding);
    </script>
</body>
</html>

<style is:global>
  /* 1. Definición de la fuente local Ethnocentric */
  @font-face {
    font-family: 'Ethnocentric';
    src: url('/fonts/ethnocentric_rg.ttf') format('truetype');
    font-weight: normal;
    font-style: normal;
    font-display: swap;
  }

  /* 2. Clase Global para títulos impactantes */
  .font-brand {
    font-family: 'Ethnocentric', sans-serif;
    letter-spacing: 0.03em;
    text-transform: uppercase;
  }
</style>