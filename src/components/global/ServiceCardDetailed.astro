---
// src/components/ServiceCardDetailed.astro
interface Props {
    title: string;
    description: string;
    icon: string;
    image: string;
    link: string;
    features: string[];
}

const { title, description, icon, image, link, features } = Astro.props;
---

<div class="group bg-white dark:bg-zinc-900 rounded-3xl overflow-hidden shadow-xl border border-gray-100 dark:border-zinc-800 transition-all hover:shadow-2xl flex flex-col">
    <div class="relative h-64 overflow-hidden">
        <img src={image} alt={title} class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" />
        <div class="absolute top-4 left-4 bg-[#f0ba18] text-black w-12 h-12 rounded-xl flex items-center justify-center shadow-lg">
            <i class={`${icon} text-xl`}></i>
        </div>
    </div>

    <div class="p-8 flex-1 flex flex-col">
        <h3 class="text-2xl font-bold mb-4 text-gray-900 dark:text-white group-hover:text-[#f0ba18] transition-colors">
            {title}
        </h3>
        <p class="text-gray-600 dark:text-gray-400 mb-6 leading-relaxed">
            {description}
        </p>

        <ul class="space-y-3 mb-8 flex-1">
            {features.map((feature) => (
                <li class="flex items-center text-sm text-gray-700 dark:text-gray-300">
                    <i class="fas fa-check-circle text-[#f0ba18] mr-2"></i>
                    {feature}
                </li>
            ))}
        </ul>

        <a href={link} class="text-center bg-zinc-100 dark:bg-zinc-800 text-gray-900 dark:text-white font-bold py-3 rounded-xl hover:bg-[#f0ba18] hover:text-black transition-all">
            Más información
        </a>
    </div>
</div>