---
// src/components/index/HeroSection.astro
---

<section class="relative w-full pt-40 pb-32 md:pt-48 md:pb-48 px-6 md:px-12 overflow-hidden bg-zinc-900">
    
    <div class="absolute inset-0 bg-cover bg-center transition-transform duration-[10s] hover:scale-105 opacity-50"
         style="background-image: url('/img/about-hero.jpg');">
    </div>
    
    <div class="absolute inset-0 bg-gradient-to-t from-zinc-50 dark:from-zinc-950 via-black/60 to-transparent z-0"></div>

    <div class="relative z-10 max-w-4xl mx-auto text-center flex flex-col items-center">
        
        <div class="inline-flex items-center px-4 py-1.5 rounded-full text-xs font-bold uppercase bg-[#f0ba18] text-black mb-6 shadow-[0_0_15px_rgba(240,186,24,0.4)] animate-fade-up">
            <i class="fas fa-truck-moving mr-2"></i> ¿Pensando en mudarte?
        </div>

        <h1 class="font-brand text-5xl md:text-7xl text-white font-bold leading-tight animate-fade-up uppercase tracking-wide drop-shadow-2xl" style="animation-delay: 0.1s;">
            Servicios de <br class="md:hidden"> <span class="text-[#f0ba18] drop-shadow-md">Mudanzas</span>
        </h1>

        <p class="text-white text-lg md:text-2xl font-bold leading-relaxed mt-4 max-w-2xl animate-fade-up drop-shadow-md uppercase tracking-widest" style="animation-delay: 0.2s;">
            Local y nacional
        </p>

        <div class="flex space-x-2 mt-4 mb-8 text-2xl text-yellow-400 drop-shadow-md animate-fade-up" style="animation-delay: 0.3s;">
            <i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i>
        </div>

        <div class="mt-2 animate-fade-up" style="animation-delay: 0.4s;">
            <a href="https://wa.me/573225019305?text=Hola,%20vengo%20de%20la%20web,%20quiero%20más%20información." target="_blank" 
               class="inline-flex items-center bg-[#f0ba18] text-black font-bold text-lg px-10 py-4 rounded-xl transition-all duration-300 transform hover:-translate-y-1 hover:bg-yellow-400 shadow-[0_0_20px_rgba(240,186,24,0.3)]">
                ¡Cotiza Ahora!
                <i class="fab fa-whatsapp ml-3 text-xl"></i>
            </a>
        </div>
        
    </div>
</section>

<style>
    /* Animación de entrada suave hacia arriba (idéntica a Cobertura) */
    .animate-fade-up {
        animation: fadeUp 0.8s ease-out forwards;
        opacity: 0;
        transform: translateY(20px);
    }

    @keyframes fadeUp {
        to { opacity: 1; transform: translateY(0); }
    }
</style>