---
// src/components/about/AboutValues.astro
---
<section class="py-16 md:py-24 bg-zinc-50 dark:bg-zinc-900 border-y border-border transition-colors duration-300">
    <div class="px-6 md:px-12">
        
        <div class="text-center mb-16">
            <h2 class="font-brand text-2xl md:text-4xl text-gray-900 dark:text-white uppercase">
                Nuestra Brújula
            </h2>
            <div class="w-24 h-1 bg-[#f0ba18] mx-auto mt-4 rounded-full"></div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            
            <div class="bg-white dark:bg-black p-8 rounded-3xl shadow-lg group hover:-translate-y-2 transition-all duration-300 flex flex-col items-start border border-border">
                <div class="w-14 h-14 bg-yellow-100 dark:bg-yellow-900/20 rounded-2xl flex items-center justify-center mb-6 text-[#f0ba18]">
                    <i class="fas fa-bullseye text-2xl"></i>
                </div>
                <h3 class="font-brand text-xl text-gray-900 dark:text-white uppercase mb-3">Misión</h3>
                <p class="text-gray-600 dark:text-gray-400 font-sans leading-relaxed text-sm md:text-base">
                    Proveer soluciones logísticas integrales, superando expectativas mediante excelencia operativa y calidez humana.
                </p>
            </div>

            <div class="bg-white dark:bg-black p-8 rounded-3xl shadow-lg group hover:-translate-y-2 transition-all duration-300 flex flex-col items-start border border-border">
                <div class="w-14 h-14 bg-blue-50 dark:bg-blue-900/20 rounded-2xl flex items-center justify-center mb-6 text-blue-600 dark:text-blue-400">
                    <i class="fas fa-eye text-2xl"></i>
                </div>
                <h3 class="font-brand text-xl text-gray-900 dark:text-white uppercase mb-3">Visión 2028</h3>
                <p class="text-gray-600 dark:text-gray-400 font-sans leading-relaxed text-sm md:text-base">
                    Ser líderes nacionales en transporte de carga, reconocidos por nuestra innovación tecnológica y flota moderna.
                </p>
            </div>

            <div class="bg-[#f0ba18] p-8 rounded-3xl shadow-lg hover:-translate-y-2 transition-all duration-300 flex flex-col justify-center relative overflow-hidden group">
                <div class="absolute top-0 right-0 p-4 opacity-10">
                    <i class="fas fa-star text-8xl text-black"></i>
                </div>
                <h3 class="font-brand text-2xl text-black uppercase mb-6 relative z-10">Valores RG</h3>
                <div class="grid grid-cols-2 gap-4 relative z-10">
                    <div class="bg-white/20 backdrop-blur-sm p-3 rounded-xl flex flex-col items-center text-center">
                        <i class="fas fa-shield-alt text-black text-xl mb-1"></i>
                        <span class="text-black font-bold text-xs uppercase">Seguridad</span>
                    </div>
                    <div class="bg-white/20 backdrop-blur-sm p-3 rounded-xl flex flex-col items-center text-center">
                        <i class="fas fa-clock text-black text-xl mb-1"></i>
                        <span class="text-black font-bold text-xs uppercase">Cumplimiento</span>
                    </div>
                    <div class="bg-white/20 backdrop-blur-sm p-3 rounded-xl flex flex-col items-center text-center">
                        <i class="fas fa-handshake text-black text-xl mb-1"></i>
                        <span class="text-black font-bold text-xs uppercase">Honestidad</span>
                    </div>
                    <div class="bg-white/20 backdrop-blur-sm p-3 rounded-xl flex flex-col items-center text-center">
                        <i class="fas fa-heart text-black text-xl mb-1"></i>
                        <span class="text-black font-bold text-xs uppercase">Pasión</span>
                    </div>
                </div>
            </div>

        </div>
    </div>
</section>