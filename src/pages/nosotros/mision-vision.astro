---
// Importamos el layout. 
import MainLayout from '../../layouts/MainLayout.astro';
import WhatsAppBtn from '../../components/global/WhatsAppBtn.astro';

const valores = [
    { titulo: 'Seguridad', icono: 'fas fa-shield-alt', desc: 'Protegemos tu mercancía como si fuera nuestra.' },
    { titulo: 'Cumplimiento', icono: 'fas fa-stopwatch', desc: 'Entregas a tiempo, respetando cada cronograma.' },
    { titulo: 'Compromiso', icono: 'fas fa-handshake', desc: 'Trato humano y responsable en cada ruta.' },
    { titulo: 'Innovación', icono: 'fas fa-lightbulb', desc: 'Mejoramos constantemente nuestros procesos.' }
];
---

<MainLayout title="Misión y Visión | Grupo Transporte RG">
    
    <section class="relative w-full pt-40 pb-32 md:pt-48 md:pb-48 px-6 md:px-12 overflow-hidden bg-zinc-900">
    
        <div class="absolute inset-0 bg-cover bg-center transition-transform duration-[10s] hover:scale-105 opacity-50"
            style="background-image: url('/img/about-hero.jpg');">
        </div>
        
        <div class="absolute inset-0 bg-gradient-to-t from-zinc-50 dark:from-zinc-950 via-black/70 to-transparent z-0"></div>

        <div class="relative z-10 max-w-4xl mx-auto text-center flex flex-col items-center">
            <div class="inline-flex items-center px-4 py-1.5 rounded-full text-xs font-bold uppercase bg-[#f0ba18] text-black mb-6 shadow-[0_0_15px_rgba(240,186,24,0.4)] animate-fade-up">
                <i class="fas fa-compass mr-2"></i> Nuestro Propósito
            </div>

            <h1 class="font-brand text-5xl md:text-7xl text-white font-bold leading-tight animate-fade-up uppercase tracking-wide drop-shadow-2xl" style="animation-delay: 0.1s;">
                Misión y <span class="text-[#f0ba18] drop-shadow-md">Visión</span>
            </h1>

            <p class="text-gray-300 text-lg md:text-2xl font-light leading-relaxed mt-6 max-w-2xl animate-fade-up drop-shadow-md" style="animation-delay: 0.2s;">
                El motor que impulsa cada uno de nuestros viajes y el destino hacia el que dirigimos nuestro futuro.
            </p>
        </div>
    </section>

    <div class="w-full bg-zinc-50 dark:bg-zinc-950 transition-colors duration-500 pb-24">
        
        <div class="max-w-7xl mx-auto px-4 sm:px-6 relative z-20 -mt-24 md:-mt-32 mb-20">
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
                
                <div class="group bg-white dark:bg-zinc-900 rounded-[2rem] p-8 md:p-12 shadow-xl hover:shadow-2xl transition-all duration-500 border border-gray-100 dark:border-zinc-800 animate-fade-up relative overflow-hidden">
                    
                    <div class="absolute top-0 right-0 opacity-5 dark:opacity-10 pointer-events-none mt-8 mr-8 transition-transform duration-700 group-hover:scale-110">
                        <i class="fas fa-bullseye text-[10rem] text-black dark:text-white"></i>
                    </div>

                    <div class="relative z-10">
                        <div class="w-16 h-16 rounded-2xl bg-[#f0ba18]/10 text-[#f0ba18] flex items-center justify-center mb-8 group-hover:scale-110 transition-transform duration-300 border border-[#f0ba18]/20">
                            <i class="fas fa-bullseye text-3xl"></i>
                        </div>
                        <h2 class="text-3xl md:text-4xl font-brand text-black dark:text-white mb-6 uppercase tracking-wide">
                            Nuestra <span class="text-[#f0ba18]">Misión</span>
                        </h2>
                        <p class="text-gray-600 dark:text-gray-400 text-lg leading-relaxed font-light">
                            Brindar soluciones integrales de transporte y logística a nivel nacional, garantizando la seguridad, puntualidad y el cuidado de las mercancías de nuestros clientes. 
                            <br><br>
                            Nos esforzamos por ofrecer un <strong class="text-black dark:text-white font-bold">servicio humano y personalizado</strong>, apoyados en un equipo altamente capacitado y un parque automotor óptimo, para ser el aliado estratégico que impulse el crecimiento de quienes confían en nosotros.
                        </p>
                    </div>
                </div>

                <div class="group bg-[#f0ba18] rounded-[2rem] p-8 md:p-12 shadow-xl hover:shadow-2xl transition-all duration-500 transform hover:-translate-y-2 animate-fade-up relative overflow-hidden" style="animation-delay: 0.2s;">
                    
                    <div class="absolute top-0 right-0 opacity-10 pointer-events-none mt-8 mr-8 transition-transform duration-700 group-hover:scale-110">
                        <i class="fas fa-eye text-[10rem] text-black"></i>
                    </div>

                    <div class="relative z-10 flex flex-col h-full">
                        <div class="w-16 h-16 rounded-2xl bg-black/10 text-black flex items-center justify-center mb-8 group-hover:rotate-12 transition-transform duration-300">
                            <i class="fas fa-rocket text-3xl"></i>
                        </div>
                        <h2 class="text-3xl md:text-4xl font-brand text-black mb-6 uppercase tracking-wide">
                            Nuestra Visión
                        </h2>
                        <p class="text-black/80 text-lg leading-relaxed font-medium">
                            Para el año 2028, <strong class="text-black font-black">Grupo Transporte RG</strong> se proyecta como una de las empresas líderes en el sector de transporte de carga y logística en Colombia.
                            <br><br>
                            Seremos reconocidos por nuestra innovación tecnológica, la expansión constante de nuestras rutas y un compromiso inquebrantable con la sostenibilidad, estableciendo el estándar de excelencia en el servicio logístico nacional.
                        </p>
                    </div>
                </div>

                <div class="md:col-span-2 group bg-white dark:bg-zinc-900 rounded-[2rem] p-8 md:p-12 shadow-xl hover:shadow-2xl transition-all duration-500 border border-gray-100 dark:border-zinc-800 animate-fade-up" style="animation-delay: 0.4s;">
                    <div class="text-center mb-10">
                        <h2 class="text-3xl md:text-4xl font-brand text-black dark:text-white uppercase tracking-wide">
                            Nuestros <span class="text-[#f0ba18]">Valores</span>
                        </h2>
                        <p class="text-gray-500 dark:text-gray-400 mt-3 font-light">Los pilares que sostienen cada kilómetro recorrido.</p>
                    </div>

                    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
                        {valores.map((valor) => (
                            <div class="flex flex-col items-center text-center space-y-4 p-4 rounded-2xl hover:bg-gray-50 dark:hover:bg-zinc-800/50 transition-colors">
                                <div class="w-14 h-14 rounded-full bg-gray-100 dark:bg-zinc-800 text-[#f0ba18] flex items-center justify-center shadow-inner">
                                    <i class={`${valor.icono} text-xl`}></i>
                                </div>
                                <h3 class="text-xl font-bold text-black dark:text-white">{valor.titulo}</h3>
                                <p class="text-sm text-gray-600 dark:text-gray-400 font-light leading-relaxed">
                                    {valor.desc}
                                </p>
                            </div>
                        ))}
                    </div>
                </div>

            </div>
        </div>

        <div class="max-w-5xl mx-auto px-6 animate-fade-up" style="animation-delay: 0.6s;">
            <div class="bg-black dark:bg-zinc-900 rounded-[2rem] p-10 md:p-14 text-center shadow-2xl border border-zinc-800 relative overflow-hidden group">
                
                <div class="absolute top-0 right-0 w-64 h-64 bg-[#f0ba18] opacity-10 rounded-full blur-3xl -mr-20 -mt-20 group-hover:opacity-20 transition-opacity duration-500"></div>
                <div class="absolute bottom-0 left-0 w-64 h-64 bg-[#f0ba18] opacity-10 rounded-full blur-3xl -ml-20 -mb-20 group-hover:opacity-20 transition-opacity duration-500"></div>

                <div class="relative z-10">
                    <h2 class="font-brand text-3xl md:text-5xl text-white uppercase tracking-wide mb-6">
                        ¿Compartes <span class="text-[#f0ba18]">Nuestra Visión?</span>
                    </h2>
                    <p class="text-gray-300 text-lg md:text-xl mb-10 max-w-2xl mx-auto font-light">
                        Deja tu carga en manos de un equipo que trabaja con propósito, seguridad y pasión.
                    </p>
                    
                    <WhatsAppBtn texto="Hablemos de tu envío"/>
                </div>
            </div>
        </div>

    </div>
</MainLayout>

<style>
    .animate-fade-up {
        animation: fadeUp 0.8s ease-out forwards;
        opacity: 0;
        transform: translateY(20px);
    }

    @keyframes fadeUp {
        to { opacity: 1; transform: translateY(0); }
    }
</style>