---
// Importamos el layout. 
// OJO: Como ahora estamos en una subcarpeta (nosotros/), agregamos '../' extra
import MainLayout from '../../layouts/MainLayout.astro';

// Aquí puedes editar fácilmente las ciudades y zonas de cobertura
const zonasCobertura = [
    {
        region: 'Centro y Andina',
        ciudades: 'Bogotá, Medellín, Bucaramanga, Tunja, Ibagué.',
        icon: 'fas fa-map-marked-alt'
    },
    {
        region: 'Costa Caribe',
        ciudades: 'Barranquilla, Cartagena, Santa Marta, Valledupar.',
        icon: 'fas fa-sun'
    },
    {
        region: 'Occidente y Pacífico',
        ciudades: 'Cali, Buenaventura, Popayán, Pasto.',
        icon: 'fas fa-route'
    },
    {
        region: 'Eje Cafetero',
        ciudades: 'Pereira, Manizales, Armenia, Cartago.',
        icon: 'fas fa-coffee'
    },
    {
        region: 'Llanos Orientales',
        ciudades: 'Villavicencio, Yopal, Arauca.',
        icon: 'fas fa-tree'
    },
    {
        region: 'Norte de Santander',
        ciudades: 'Cúcuta, Pamplona, Ocaña.',
        icon: 'fas fa-mountain'
    }
];
---

<MainLayout title="Nuestra Cobertura | Grupo Transporte RG">
    
    <section class="relative w-full pt-40 pb-20 md:pt-48 md:pb-28 px-6 md:px-12 overflow-hidden bg-zinc-900">
    
        <div class="absolute inset-0 bg-cover bg-center transition-transform duration-[10s] hover:scale-105 opacity-60"
            style="background-image: url('/img/about-hero.jpg');">
        </div>
        
        <div class="absolute inset-0 bg-gradient-to-t from-zinc-50 dark:from-zinc-950 via-black/60 to-transparent z-0"></div>

        <div class="relative z-10 max-w-4xl mx-auto text-center flex flex-col items-center">
            <div class="inline-flex items-center px-4 py-1.5 rounded-full text-xs font-bold uppercase bg-[#f0ba18] text-black mb-6 shadow-[0_0_15px_rgba(240,186,24,0.4)] animate-fade-up">
                <i class="fas fa-truck mr-2"></i> Llegamos a tu destino
            </div>

            <h1 class="font-brand text-5xl md:text-7xl text-white font-bold leading-tight animate-fade-up uppercase tracking-wide drop-shadow-2xl" style="animation-delay: 0.1s;">
                Nuestra <br class="md:hidden"> <span class="text-[#f0ba18] drop-shadow-md">Cobertura</span>
            </h1>

            <p class="text-white text-lg md:text-xl font-medium leading-relaxed mt-6 max-w-2xl animate-fade-up drop-shadow-md" style="animation-delay: 0.2s;">
                Conectamos el progreso de Colombia. Llevamos tus mercancías, mudanzas y sueños a cualquier rincón del país con seguridad y cumplimiento.
            </p>
        </div>
    </section>

    <div class="w-full bg-zinc-50 dark:bg-zinc-950 transition-colors duration-500 pb-24">
        
        <div class="max-w-7xl mx-auto px-6 relative z-20 -mt-10 mb-20">
            
            <div class="text-center mb-16 animate-fade-up" style="animation-delay: 0.3s;">
                <h2 class="text-3xl md:text-4xl font-extrabold text-black dark:text-white mb-4">
                    Rutas <span class="text-[#f0ba18]">Nacionales</span>
                </h2>
                <p class="text-gray-600 dark:text-gray-400 text-lg max-w-2xl mx-auto">
                    Nuestra logística nos permite operar en las principales vías del territorio nacional, asegurando tiempos de entrega óptimos.
                </p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                {zonasCobertura.map((zona, index) => (
                    <div class="group bg-white dark:bg-zinc-900 rounded-3xl p-8 shadow-md hover:shadow-xl transition-all duration-500 border border-gray-100 dark:border-zinc-800 hover:border-[#f0ba18] animate-fade-up" style={`animation-delay: ${0.4 + (index * 0.1)}s;`}>
                        <div class="w-16 h-16 rounded-full bg-[#f0ba18]/10 text-[#f0ba18] flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-300">
                            <i class={`${zona.icon} text-2xl`}></i>
                        </div>
                        <h3 class="text-2xl font-bold mb-3 text-black dark:text-white">{zona.region}</h3>
                        <p class="text-gray-600 dark:text-gray-400 text-base leading-relaxed">
                            {zona.ciudades}
                        </p>
                    </div>
                ))}
            </div>
        </div>

        <div class="max-w-5xl mx-auto px-6 animate-fade-up" style="animation-delay: 0.8s;">
            <div class="bg-black dark:bg-zinc-900 rounded-[2rem] p-10 md:p-14 text-center shadow-2xl border border-zinc-800 relative overflow-hidden">
                
                <div class="absolute top-0 right-0 w-64 h-64 bg-[#f0ba18] opacity-10 rounded-full blur-3xl -mr-20 -mt-20"></div>
                <div class="absolute bottom-0 left-0 w-64 h-64 bg-[#f0ba18] opacity-10 rounded-full blur-3xl -ml-20 -mb-20"></div>

                <div class="relative z-10">
                    <h2 class="font-brand text-3xl md:text-5xl text-white uppercase tracking-wide mb-6">
                        ¿Tu destino no está <span class="text-[#f0ba18]">en la lista?</span>
                    </h2>
                    <p class="text-gray-300 text-lg md:text-xl mb-10 max-w-2xl mx-auto">
                        Realizamos viajes especiales y rutas personalizadas según la necesidad de tu carga o mudanza. Pregúntanos sin compromiso.
                    </p>
                    
                    <a href="https://wa.me/573225019305?text=Hola,%20quisiera%20saber%20si%20tienen%20cobertura%20hacia%20un%20destino%20específico." target="_blank" 
                       class="inline-flex items-center bg-[#f0ba18] text-black font-bold text-lg px-10 py-4 rounded-xl transition-all duration-300 transform hover:-translate-y-1 hover:bg-yellow-400 shadow-[0_0_20px_rgba(240,186,24,0.3)]">
                        Consultar Ruta
                        <i class="fab fa-whatsapp ml-3 text-xl"></i>
                    </a>
                </div>
            </div>
        </div>

    </div>
</MainLayout>

<style>
    .animate-fade-up {
        animation: fadeUp 0.8s ease-out forwards;
        opacity: 0;
        transform: translateY(20px);
    }

    @keyframes fadeUp {
        to { opacity: 1; transform: translateY(0); }
    }
</style>